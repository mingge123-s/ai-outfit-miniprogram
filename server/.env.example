# 二选一：配置 OPENAI_API_KEY（OpenAI 兼容网关）或 GEMINI_API_KEY（Google AI Studio）
# 配置了 OPENAI_API_KEY 时默认走 openai 兼容接口（/v1/images/edits）

# 方式 A：OpenAI 兼容生图 API（如 ai.gs88.shop 等代理网关）
OPENAI_API_KEY=sk-your_key_here
OPENAI_BASE_URL=https://ai.gs88.shop
# MODEL_ID=gpt-image-2
# 高质量档在 Cloudflare 网关下易 524 超时，建议 low
# IMAGE_QUALITY=low

# 方式 B：Google Gemini（https://aistudio.google.com/app/apikey）
# GEMINI_API_KEY=your_api_key_here
# MODEL_ID=gemini-2.5-flash-image-preview

# 方式 C：火山方舟 豆包 Seedream（https://console.volcengine.com/ark）
# ARK_API_KEY=your_ark_key_here
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MODEL_ID=doubao-seedream-5-0-pro-260628
# ARK_SIZE=2k
# ARK_RESPONSE_FORMAT=url
# ARK_WATERMARK=0

# PROVIDER=ark | openai | gemini（默认按已配置的 key 自动选择，优先 ark）
# 微信登录（小程序后台获取）；不配置时为开发模式（本地调试可直接登录）
# WX_APPID=your_appid
# WX_SECRET=your_secret

# 衣柜图片后台处理（0=关闭，其他值或未配置=开启）
# AUTO_CUTOUT=1
# VISION_API_KEY=your_vision_api_key
# VISION_BASE_URL=https://ai.gs88.shop/v1
# VISION_MODEL=gpt-5.4-mini
# AUTO_CATEGORY=1

# 次数/积分（均须为正整数）
DAILY_FREE_LIMIT=10
FREE_SIGNUP_CREDITS=3
CREDITS_PER_GENERATION=1
# 管理员 HTTP 接口令牌；未配置时管理接口关闭
# ADMIN_TOKEN=请替换为随机长字符串

PORT=3000
