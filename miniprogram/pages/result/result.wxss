.page {
  padding: 32rpx 40rpx 260rpx;
  background: #f8f9fa;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 效果图 */
.hero-wrap {
  position: relative;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.05);
  background: #f0edf1;
}
.hero-image {
  width: 100%;
  display: block;
}
.float-label {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #1b1b1e;
}

/* 搭配单品 */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 48rpx 0 24rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1b1b1e;
}
.section-sub {
  font-size: 24rpx;
  color: #767586;
}
.items-scroll {
  white-space: nowrap;
  display: flex;
}
.item-cell {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 240rpx;
  margin-right: 28rpx;
}
.item-thumb-wrap {
  width: 240rpx;
  height: 240rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e4e1e6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 12rpx;
}
.item-thumb {
  width: 100%;
  height: 100%;
  padding: 8rpx;
  box-sizing: border-box;
}
.item-name {
  font-size: 24rpx;
  color: #464554;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 48rpx calc(32rpx + env(safe-area-inset-bottom));
  background: rgba(248, 249, 250, 0.92);
  backdrop-filter: blur(30rpx);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 50;
}
.action-row {
  display: flex;
  gap: 16rpx;
}
.action-row + .action-row { margin-top: 16rpx; }
.action-row button {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.save-btn {
  box-shadow: 0 12rpx 30rpx rgba(92, 124, 141, 0.25);
  background: #5c7c8d;
}
.collect-btn {
  color: #5c7c8d;
  background: #eef3f5;
  border: 2rpx solid #5c7c8d;
}
.regen-btn {
  color: #ffffff;
  border: 2rpx solid #47616f;
  background: #47616f;
}
.edit-btn {
  color: #47616f;
  border: 2rpx solid #c9d3d8;
  background: transparent;
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(248, 249, 250, 0.95);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.loading-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 40rpx;
  animation: pulse-ai 2s ease-in-out infinite;
}
.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5c7c8d;
}
@keyframes pulse-ai {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}

/* 生成中/失败占位 */
.pending-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}
.pending-icon {
  margin-bottom: 32rpx;
}
.pending-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5c7c8d;
  margin-bottom: 16rpx;
}
.pending-sub {
  font-size: 26rpx;
  color: #8a8a99;
  margin-top: 8rpx;
}
