.page {
  padding: 32rpx 40rpx 260rpx;
  background: #fbf8fc;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 效果图 */
.hero-wrap {
  position: relative;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.05);
  background: #f0edf1;
}
.hero-image {
  width: 100%;
  display: block;
}
.float-label {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #1b1b1e;
}

/* 搭配单品 */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 48rpx 0 24rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1b1b1e;
}
.section-sub {
  font-size: 24rpx;
  color: #767586;
}
.items-scroll {
  white-space: nowrap;
  display: flex;
}
.item-cell {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 240rpx;
  margin-right: 28rpx;
}
.item-thumb-wrap {
  width: 240rpx;
  height: 240rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e4e1e6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 12rpx;
}
.item-thumb {
  width: 100%;
  height: 100%;
  padding: 8rpx;
  box-sizing: border-box;
}
.item-name {
  font-size: 24rpx;
  color: #464554;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 48rpx calc(32rpx + env(safe-area-inset-bottom));
  background: rgba(251, 248, 252, 0.85);
  backdrop-filter: blur(30rpx);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.05);
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 50;
}
.save-btn {
  width: 100%;
  height: 108rpx;
  line-height: 108rpx;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 30rpx rgba(99, 102, 241, 0.35);
  background: #5c7c8d;
}
.collect-btn {
  width: 100%;
  height: 100rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #5c7c8d;
  background: #eef3f5;
  border: 3rpx solid #5c7c8d;
}
.regen-btn {
  width: 100%;
  height: 100rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #4648d4;
  border: 3rpx solid #4648d4;
  background: transparent;
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(251, 248, 252, 0.95);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.loading-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 40rpx;
  animation: pulse-ai 2s ease-in-out infinite;
}
.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #4648d4;
}
@keyframes pulse-ai {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}
