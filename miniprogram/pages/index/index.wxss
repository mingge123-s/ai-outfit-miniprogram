.page {
  padding: 32rpx 32rpx 220rpx;
}

/* Hero */
.hero {
  margin: 16rpx 0 40rpx;
  display: flex;
  flex-direction: column;
}
.hero-label {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #3525cd;
  margin-bottom: 8rpx;
}
.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #191c1d;
  white-space: pre-line;
}

/* 虚线卡片 */
.dashed {
  border: 3rpx dashed #3525cd;
  border-radius: 24rpx;
  background: #f3f4f5;
  position: relative;
  overflow: hidden;
}
.dashed.filled {
  border-style: solid;
  border-color: #c7c4d8;
  background: #ffffff;
}

/* 模特上传 */
.person-card {
  width: 100%;
  height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.person-preview {
  width: 100%;
  height: 100%;
}
.person-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.person-icon {
  font-size: 56rpx;
}
.person-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #3525cd;
}
.person-hint {
  font-size: 22rpx;
  color: #777587;
  margin-top: 12rpx;
}

/* 分区标题 */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin: 48rpx 0 24rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #464555;
  letter-spacing: 2rpx;
}
.section-sub {
  font-size: 24rpx;
  color: #3525cd;
}

/* 单品网格 */
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.item-card {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.item-preview {
  width: 100%;
  height: 100%;
}
.item-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}
.item-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #191c1d;
}
.item-hint {
  font-size: 18rpx;
  color: rgba(53, 37, 205, 0.6);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}
.item-tag {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.fav-btn {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(108, 92, 231, 0.85);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 46rpx;
  text-align: center;
  z-index: 2;
}
.remove-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 32rpx;
  line-height: 44rpx;
  text-align: center;
  z-index: 2;
}

/* 风格标签 */
.more-toggle { margin-top: 20rpx; padding: 18rpx 0; text-align: center; border: 2rpx dashed #d5d5e0; border-radius: 16rpx; background: #fff; color: #8a8a99; font-size: 24rpx; }

.chips {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}
.custom-bg {
  margin-top: 20rpx;
  padding: 18rpx 24rpx;
  border: 2rpx solid #d5d5e0;
  border-radius: 16rpx;
  background: #fff;
  font-size: 26rpx;
}
.chip {
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: #e1e3e4;
  color: #464555;
  font-size: 26rpx;
  font-weight: 600;
}
.chip-active {
  background: #3525cd;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(53, 37, 205, 0.3);
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #f8f9fa;
  box-shadow: 0 -8rpx 40rpx rgba(79, 70, 229, 0.05);
  z-index: 50;
}
.generate-btn {
  width: 100%;
  height: 112rpx;
  line-height: 112rpx;
  border-radius: 24rpx;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 30rpx rgba(53, 37, 205, 0.3);
}
.generate-btn.disabled {
  opacity: 0.5;
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(248, 249, 250, 0.95);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.loading-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 40rpx;
  animation: pulse-ai 2s ease-in-out infinite;
}
.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #3525cd;
}
.loading-hint {
  font-size: 24rpx;
  color: #777587;
  margin-top: 12rpx;
}
@keyframes pulse-ai {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}
