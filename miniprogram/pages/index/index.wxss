.page {
  padding: 32rpx 32rpx 220rpx;
}

/* Hero */
.hero {
  margin: 8rpx 0 20rpx;
  display: flex;
  flex-direction: column;
}
.hero-label {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #5c7c8d;
  margin-bottom: 8rpx;
}
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #191c1d;
  white-space: pre-line;
}

.today-entry {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  margin-bottom: 22rpx;
  border-radius: 22rpx;
  color: #fff;
  background: linear-gradient(120deg, #496673, #76919d);
  box-shadow: 0 10rpx 28rpx rgba(73, 102, 115, .2);
}
.today-entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  margin-right: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, .16);
  font-size: 38rpx;
}
.today-entry-copy { display: flex; flex: 1; flex-direction: column; }
.today-entry-title { font-size: 30rpx; font-weight: 700; }
.today-entry-sub { margin-top: 5rpx; font-size: 21rpx; opacity: .85; }
.today-entry-arrow { font-size: 46rpx; opacity: .8; }

/* 虚线卡片 */
.dashed {
  border: 3rpx dashed #5c7c8d;
  border-radius: 24rpx;
  background: #f3f4f5;
  position: relative;
  overflow: hidden;
}
.dashed.filled {
  border-style: solid;
  border-color: #c7c4d8;
  background: #ffffff;
}

/* 模特上传 */
.person-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}
.person-row .person-card {
  flex: 1;
}
.switch-person {
  flex: 0 0 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  white-space: pre-line;
  border: 2rpx solid #e2e6e9;
  border-radius: 20rpx;
  background: #ffffff;
  color: #47616f;
  font-size: 24rpx;
  line-height: 1.6;
}
.person-card {
  width: 100%;
  height: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.person-preview {
  width: 100%;
  height: 100%;
}
.person-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.person-icon {
  font-size: 44rpx;
}
.person-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #5c7c8d;
}
.person-hint {
  font-size: 22rpx;
  color: #777587;
  margin-top: 12rpx;
}

/* 分区标题 */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin: 28rpx 0 16rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #464555;
  letter-spacing: 2rpx;
}
.section-sub {
  font-size: 24rpx;
  color: #5c7c8d;
}

/* 单品网格 */
.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.item-card {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.item-preview {
  width: 100%;
  height: 100%;
}
.item-icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
}
.item-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #191c1d;
}
.item-hint {
  font-size: 18rpx;
  color: rgba(92, 124, 141, 0.8);
  margin-top: 8rpx;
  white-space: nowrap;
}
.item-tag {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.fav-btn {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(92, 124, 141, 0.85);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 46rpx;
  text-align: center;
  z-index: 2;
}
.remove-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 32rpx;
  line-height: 44rpx;
  text-align: center;
  z-index: 2;
}

/* 风格标签 */
.more-toggle { margin-top: 20rpx; padding: 18rpx 0; text-align: center; border: 2rpx dashed #d5d5e0; border-radius: 16rpx; background: #fff; color: #8a8a99; font-size: 24rpx; }

.chips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}
.custom-bg-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}
.custom-bg {
  flex: 1;
  padding: 18rpx 24rpx;
  border: 2rpx solid #d5d5e0;
  border-radius: 16rpx;
  background: #fff;
  font-size: 26rpx;
}
.save-tag-btn {
  flex: 0 0 auto;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: #5c7c8d;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
.bg-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}
.bg-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef0f2;
  color: #464555;
  font-size: 22rpx;
}
.bg-tag-active {
  background: #5c7c8d;
  color: #fff;
}
.bg-tag-del {
  font-size: 28rpx;
  line-height: 1;
  opacity: 0.7;
}
.bg-tags-hint {
  display: block;
  margin-top: 12rpx;
  color: #a0a0ad;
  font-size: 22rpx;
}
.chip {
  flex: 0 0 calc((100% - 60rpx) / 6);
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: #e1e3e4;
  color: #464555;
  font-size: 22rpx;
  font-weight: 600;
}
.chip-active {
  background: #5c7c8d;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(92, 124, 141, 0.3);
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #f8f9fa;
  box-shadow: 0 -8rpx 40rpx rgba(92, 124, 141, 0.05);
  z-index: 50;
}
.generate-btn {
  width: 100%;
  height: 112rpx;
  border-radius: 24rpx;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0;
  box-shadow: 0 12rpx 30rpx rgba(92, 124, 141, 0.3);
}
.generate-btn.disabled,
.generate-btn[disabled] {
  background: #d7dde0 !important;
  color: #5f7078 !important;
  border: 2rpx solid #c4cdd1 !important;
  opacity: 1 !important;
  box-shadow: 0 10rpx 26rpx rgba(92, 124, 141, 0.18) !important;
}
.quota-hint {
  display: block;
  margin-top: 10rpx;
  text-align: center;
  color: #777587;
  font-size: 22rpx;
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(248, 249, 250, 0.95);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.loading-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 40rpx;
  animation: pulse-ai 2s ease-in-out infinite;
}
.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5c7c8d;
}
.loading-hint {
  font-size: 24rpx;
  color: #777587;
  margin-top: 12rpx;
}
@keyframes pulse-ai {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}
