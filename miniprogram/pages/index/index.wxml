<view class="page">
  <!-- Hero -->
  <view class="hero">
    <text class="hero-label">DESIGN YOUR STYLE</text>
    <text class="hero-title">即刻开启\n数字时尚之旅</text>
  </view>

  <!-- 穿搭单品 -->
  <view class="section-head">
    <text class="section-title">① 选穿搭单品</text>
    <text class="section-sub">至少上传 1 件</text>
  </view>
  <view class="grid">
    <view
      wx:for="{{items}}"
      wx:key="key"
      wx:if="{{index < 4}}"
      class="item-card dashed {{item.path || item.wardrobeId ? 'filled' : ''}}"
      data-index="{{index}}"
      bindtap="chooseItem"
    >
      <block wx:if="{{item.path || item.wardrobeId}}">
        <image class="item-preview" src="{{item.path || item.imageUrl}}" mode="aspectFill" />
        <view class="remove-btn" catchtap="removeItem" data-index="{{index}}">×</view>
        <view class="fav-btn" wx:if="{{item.path}}" catchtap="saveItemToWardrobe" data-index="{{index}}">☆</view>
        <view class="item-tag">{{item.label}}{{item.wardrobeId ? ' · 衣柜' : ''}}</view>
      </block>
      <block wx:else>
        <text class="item-icon">{{item.icon}}</text>
        <text class="item-label">{{item.label}}</text>
        <text class="item-hint">CLICK TO UPLOAD</text>
      </block>
    </view>
  </view>

  <view class="more-toggle" bindtap="toggleMore">
    {{showMore ? '▲ 收起更多配件' : '▼ 更多配件（外套/裙装/包包/配饰/袜子）'}}
  </view>
  <view class="grid" wx:if="{{showMore}}">
    <view
      wx:for="{{items}}"
      wx:key="key"
      wx:if="{{index >= 4}}"
      class="item-card dashed {{item.path || item.wardrobeId ? 'filled' : ''}}"
      data-index="{{index}}"
      bindtap="chooseItem"
    >
      <block wx:if="{{item.path || item.wardrobeId}}">
        <image class="item-preview" src="{{item.path || item.imageUrl}}" mode="aspectFill" />
        <view class="remove-btn" catchtap="removeItem" data-index="{{index}}">×</view>
        <view class="fav-btn" wx:if="{{item.path}}" catchtap="saveItemToWardrobe" data-index="{{index}}">☆</view>
        <view class="item-tag">{{item.label}}{{item.wardrobeId ? ' · 衣柜' : ''}}</view>
      </block>
      <block wx:else>
        <text class="item-icon">{{item.icon}}</text>
        <text class="item-label">{{item.label}}</text>
        <text class="item-hint">CLICK TO UPLOAD</text>
      </block>
    </view>
  </view>

  <!-- 背景风格 -->
  <view class="section-head">
    <text class="section-title">② 选背景风格</text>
  </view>
  <view class="chips">
    <view
      wx:for="{{styles}}"
      wx:key="key"
      class="chip {{backgroundStyle === item.key ? 'chip-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="chooseStyle"
    >{{item.label}}</view>
  </view>
  <input
    wx:if="{{backgroundStyle === 'custom'}}"
    class="custom-bg"
    placeholder="描述你想要的背景，如：日本樱花街道、赛博朋克街头…"
    value="{{customBackground}}"
    bindinput="onCustomBgInput"
  />

  <!-- 模特照片（可选） -->
  <view class="section-head">
    <text class="section-title">③ 模特照片</text>
    <text class="section-sub">可选，不传则由 AI 生成模特</text>
  </view>
  <view class="person-card dashed {{person || personUrl ? 'filled' : ''}}" bindtap="choosePerson">
    <block wx:if="{{person || personUrl}}">
      <image class="person-preview" src="{{person || personUrl}}" mode="aspectFit" />
      <view class="remove-btn" catchtap="removePerson">×</view>
    </block>
    <block wx:else>
      <view class="person-icon-wrap">
        <text class="person-icon">👤</text>
      </view>
      <text class="person-label">点击上传全身照</text>
    </block>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button
      class="generate-btn gradient-btn {{canGenerate && !loading ? '' : 'disabled'}}"
      disabled="{{!canGenerate || loading}}"
      bindtap="generate"
    >✨ {{loading ? '生成中…' : '生成穿搭'}}</button>
  </view>

  <!-- 生成中遮罩 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-circle gradient-btn">✨</view>
    <text class="loading-text">AI 正在为你生成穿搭…</text>
    <text class="loading-hint">大约需要 10~30 秒</text>
  </view>
</view>
