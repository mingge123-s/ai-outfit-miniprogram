<view class="page">
  <view class="tip">可一次上传 9 张，豆包会自动识别分类；点击单品可跨分类各选 1 件</view>

  <view class="batch-status" wx:if="{{batchUploading || batchProcessingCount > 0}}">
    <view class="batch-status-row">
      <text wx:if="{{batchUploading}}">正在上传 {{batchCompleted}}/{{batchTotal}}</text>
      <text wx:else>豆包正在识别并抠图：{{batchProcessingCount}} 件</text>
      <text class="batch-failed" wx:if="{{batchFailed > 0}}">失败 {{batchFailed}}</text>
    </view>
    <view class="batch-progress" wx:if="{{batchUploading}}">
      <view class="batch-progress-inner" style="width: {{batchProgress}}%;" />
    </view>
  </view>

  <!-- 分类 -->
  <view class="chips">
    <view
      wx:for="{{categories}}"
      wx:key="key"
      class="chip {{category === item.key ? 'chip-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="switchCategory"
    >{{item.icon}} {{item.label}}</view>
  </view>

  <!-- 列表 -->
  <view class="grid">
    <view class="item-card add-card dashed {{batchUploading ? 'add-card-disabled' : ''}}" bindtap="addItem">
      <text class="add-plus">＋</text>
      <text class="add-label">{{batchUploading ? '上传中…' : '批量添加'}}</text>
    </view>
    <view
      class="item-card {{selected[item.category] && selected[item.category].id === item.id ? 'selected' : ''}}"
      wx:for="{{items}}"
      wx:key="id"
      data-item="{{item}}"
      bindtap="tapItem"
      bindlongpress="previewItem"
    >
      <image class="item-img" src="{{baseUrl}}{{item.imageUrl}}" mode="aspectFill" />
      <view class="processing-mask" wx:if="{{item.status === 'processing'}}"><text>处理中…</text></view>
      <view class="selected-check" wx:if="{{selected[item.category] && selected[item.category].id === item.id}}">✓</view>
      <view class="remove-btn" catchtap="removeItem" data-id="{{item.id}}">×</view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && items.length === 0}}">
    <text>衣柜里还没有单品，点击上方「添加单品」收藏你的衣物</text>
  </view>

  <view class="bottom-bar" wx:if="{{selectedCount > 0}}">
    <button class="use-selected" bindtap="useSelected">将选中的 {{selectedCount}} 件单品用于生成</button>
  </view>

  <!-- 淘宝商品链接导入 -->
  <view class="tb-mask" wx:if="{{tbVisible}}" bindtap="closeTaobao">
    <view class="tb-panel" catchtap="noop">
      <view class="tb-header">
        <text class="tb-title">商品链接导入</text>
        <text class="tb-close" bindtap="closeTaobao">×</text>
      </view>

      <block wx:if="{{tbStep === 'input'}}">
        <view class="tb-desc">粘贴淘宝/天猫商品链接，自动获取商品图片</view>
        <textarea
          class="tb-input"
          placeholder="例如 https://item.taobao.com/item.htm?id=..."
          value="{{tbUrl}}"
          bindinput="onTbUrlInput"
          maxlength="500"
          auto-height
        />
        <button class="tb-primary {{tbLoading ? 'disabled' : ''}}" disabled="{{tbLoading}}" bindtap="resolveTaobao">{{tbLoading ? '解析中…' : '获取商品图片'}}</button>
      </block>

      <block wx:if="{{tbStep === 'pick'}}">
        <view class="tb-goods-title" wx:if="{{tbTitle}}">{{tbTitle}}</view>
        <view class="tb-sub">选择要加入衣柜的图片（长按可预览）</view>
        <scroll-view scroll-y class="tb-imgs">
          <view class="tb-img-grid">
            <view
              class="tb-img-cell {{tbSelectedIndex === index ? 'tb-img-selected' : ''}}"
              wx:for="{{tbImages}}"
              wx:key="*this"
              data-index="{{index}}"
              bindtap="selectTbImage"
              bindlongpress="previewTbImage"
            >
              <image class="tb-img" src="{{item}}" mode="aspectFill" />
              <view class="tb-img-check" wx:if="{{tbSelectedIndex === index}}">✓</view>
            </view>
          </view>
        </scroll-view>

        <view class="tb-sub">选择分类</view>
        <view class="tb-cats">
          <view
            wx:for="{{categories}}"
            wx:key="key"
            class="chip {{tbCategory === item.key ? 'chip-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="selectTbCategory"
          >{{item.icon}} {{item.label}}</view>
        </view>

        <button class="tb-primary" bindtap="importTaobao">加入衣柜</button>
      </block>
    </view>
  </view>
</view>
