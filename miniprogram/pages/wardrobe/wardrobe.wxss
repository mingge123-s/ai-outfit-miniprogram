.page { padding: 24rpx 32rpx 180rpx; }

.tip { font-size: 26rpx; color: #5c7c8d; background: #eef3f5; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; }
.batch-status {
  margin-bottom: 20rpx; padding: 18rpx 20rpx; border-radius: 14rpx;
  background: #fff; box-shadow: 0 6rpx 20rpx rgba(92,124,141,.10);
}
.batch-status-row { display: flex; justify-content: space-between; color: #5c7c8d; font-size: 25rpx; }
.batch-failed { color: #c75b5b; }
.batch-progress { height: 10rpx; margin-top: 14rpx; overflow: hidden; border-radius: 8rpx; background: #e5eaed; }
.batch-progress-inner { height: 100%; border-radius: 8rpx; background: #5c7c8d; transition: width .2s; }

.chips { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.chip {
  flex: 0 0 calc((100% - 32rpx) / 3); box-sizing: border-box; text-align: center; padding: 16rpx 8rpx; border-radius: 16rpx;
  background: #fff; border: 2rpx solid #e3e3ee; font-size: 26rpx; color: #55556b;
}
.chip-active { border-color: #5c7c8d; background: #eef3f5; color: #5c7c8d; font-weight: 600; }
.chip-disabled { opacity: 0.4; }

.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.item-card {
  position: relative; height: 210rpx; border-radius: 16rpx; overflow: hidden; background: #fff;
}
.item-img { width: 100%; height: 100%; }
.item-card.selected { box-shadow: inset 0 0 0 6rpx #5c7c8d; }
.selected-check {
  position: absolute; left: 10rpx; top: 10rpx; width: 42rpx; height: 42rpx; line-height: 42rpx;
  text-align: center; border-radius: 50%; background: #5c7c8d; color: #fff; font-size: 26rpx; z-index: 2;
}
.add-card {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  border: 2rpx dashed #c9c9dc; background: #fbfbfe;
}
.add-card-disabled { opacity: .55; }
.dashed { border: 2rpx dashed #c9c9dc; }
.add-plus { font-size: 56rpx; color: #5c7c8d; line-height: 1; }
.add-label { font-size: 24rpx; color: #8a8a99; margin-top: 8rpx; }

.remove-btn {
  position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; line-height: 36rpx;
  text-align: center; border-radius: 50%; background: rgba(0,0,0,0.55); color: #fff; font-size: 28rpx;
}

.empty { margin-top: 80rpx; text-align: center; color: #8a8a99; font-size: 26rpx; padding: 0 40rpx; }
.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(248, 249, 250, 0.96); box-shadow: 0 -8rpx 30rpx rgba(92,124,141,.08); z-index: 20;
}
.use-selected {
  height: 96rpx; border-radius: 20rpx; background: #5c7c8d; color: #fff;
  font-size: 30rpx; font-weight: 600;
}

/* 淘宝商品链接导入 */
.tb-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 50;
  display: flex; align-items: flex-end;
}
.tb-panel {
  width: 100%; max-height: 88vh; background: #fff; border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 32rpx calc(28rpx + env(safe-area-inset-bottom)); box-sizing: border-box;
  display: flex; flex-direction: column;
}
.tb-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.tb-title { font-size: 32rpx; font-weight: 600; color: #33334d; }
.tb-close { font-size: 44rpx; color: #9a9aad; line-height: 1; padding: 0 8rpx; }
.tb-desc { font-size: 26rpx; color: #8a8a99; margin: 8rpx 0 16rpx; }
.tb-input {
  width: 100%; box-sizing: border-box; min-height: 120rpx; border: 2rpx solid #e3e3ee;
  border-radius: 16rpx; padding: 20rpx; font-size: 26rpx; color: #33334d; background: #fbfbfe;
}
.tb-primary {
  margin-top: 24rpx; height: 92rpx; border-radius: 20rpx;
  background: #5c7c8d; color: #fff; font-size: 30rpx; font-weight: 600;
}
.tb-primary.disabled { background: #d7dde0 !important; color: #5f7078 !important; opacity: 1 !important; }
.tb-goods-title { font-size: 26rpx; color: #33334d; margin: 4rpx 0 12rpx; line-height: 1.5; }
.tb-sub { font-size: 26rpx; color: #8a8a99; margin: 16rpx 0 12rpx; }
.tb-imgs { max-height: 46vh; }
.tb-img-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.tb-img-cell { position: relative; height: 200rpx; border-radius: 16rpx; overflow: hidden; background: #f2f2f7; }
.tb-img { width: 100%; height: 100%; }
.tb-img-selected { box-shadow: inset 0 0 0 6rpx #5c7c8d; }
.tb-img-check {
  position: absolute; left: 10rpx; top: 10rpx; width: 42rpx; height: 42rpx; line-height: 42rpx;
  text-align: center; border-radius: 50%; background: #5c7c8d; color: #fff; font-size: 26rpx;
}
.tb-cats { display: flex; flex-wrap: wrap; gap: 16rpx; }

.processing-mask {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.35); color: #fff; font-size: 24rpx;
}
