.page { padding: 24rpx 32rpx 180rpx; }

.tip { font-size: 26rpx; color: #5c7c8d; background: #eef3f5; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; }

.chips { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.chip {
  flex: 0 0 calc((100% - 48rpx) / 4); text-align: center; padding: 16rpx 0; border-radius: 16rpx;
  background: #fff; border: 2rpx solid #e3e3ee; font-size: 26rpx; color: #55556b;
}
.chip-active { border-color: #5c7c8d; background: #eef3f5; color: #5c7c8d; font-weight: 600; }
.chip-disabled { opacity: 0.4; }

.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.item-card {
  position: relative; height: 210rpx; border-radius: 16rpx; overflow: hidden; background: #fff;
}
.item-img { width: 100%; height: 100%; }
.item-card.selected { box-shadow: inset 0 0 0 6rpx #5c7c8d; }
.selected-check {
  position: absolute; left: 10rpx; top: 10rpx; width: 42rpx; height: 42rpx; line-height: 42rpx;
  text-align: center; border-radius: 50%; background: #5c7c8d; color: #fff; font-size: 26rpx; z-index: 2;
}
.add-card {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  border: 2rpx dashed #c9c9dc; background: #fbfbfe;
}
.dashed { border: 2rpx dashed #c9c9dc; }
.add-plus { font-size: 56rpx; color: #5c7c8d; line-height: 1; }
.add-label { font-size: 24rpx; color: #8a8a99; margin-top: 8rpx; }

.remove-btn {
  position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; line-height: 36rpx;
  text-align: center; border-radius: 50%; background: rgba(0,0,0,0.55); color: #fff; font-size: 28rpx;
}

.empty { margin-top: 80rpx; text-align: center; color: #8a8a99; font-size: 26rpx; padding: 0 40rpx; }
.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(248, 249, 250, 0.96); box-shadow: 0 -8rpx 30rpx rgba(92,124,141,.08); z-index: 20;
}
.use-selected {
  height: 96rpx; line-height: 96rpx; border-radius: 20rpx; background: #5c7c8d; color: #fff;
  font-size: 30rpx; font-weight: 600;
}
