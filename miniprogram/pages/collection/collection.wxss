.page { padding: 24rpx 32rpx 60rpx; }
.quota-tip {
  margin-bottom: 20rpx; padding: 16rpx 20rpx; border-radius: 12rpx;
  background: #eef3f5; color: #5c7c8d; font-size: 26rpx;
}

.grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.card { background: #fff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.card-name { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 18rpx 8rpx; }
.name-text { font-size: 24rpx; font-weight: 600; }
.name-empty { color: #8a8a99; font-weight: 400; }
.name-edit { font-size: 24rpx; color: #5c7c8d; padding-left: 12rpx; }
.card-img { width: 100%; height: 420rpx; display: block; }
.card-parts { padding: 12rpx 18rpx 0; }
.parts-tip { font-size: 20rpx; color: #8a8a99; }
.parts-row { white-space: nowrap; margin-top: 8rpx; }
.part { display: inline-block; position: relative; margin-right: 10rpx; }
.part-img { width: 110rpx; height: 110rpx; border-radius: 12rpx; border: 1rpx solid #ececf2; }
.part-cat { position: absolute; left: 6rpx; bottom: 10rpx; background: rgba(0,0,0,0.55); color: #fff; font-size: 16rpx; padding: 2rpx 8rpx; border-radius: 10rpx; }
.part.sel .part-img { border: 4rpx solid #5c7c8d; box-sizing: border-box; }
.part-check { position: absolute; top: 4rpx; right: 8rpx; color: #5c7c8d; font-weight: 700; font-size: 24rpx; }
.use-parts { margin-top: 12rpx; width: 100% !important; background: #5c7c8d; color: #fff; font-size: 24rpx; border-radius: 12rpx; }
.use-parts[disabled] { background: #d5d5e0; color: #fff; }
.card-bar { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 18rpx; }
.card-date { font-size: 20rpx; color: #8a8a99; }
.card-actions { display: flex; gap: 18rpx; }
.action { font-size: 30rpx; }
.danger { opacity: 0.8; }

.empty { margin-top: 120rpx; text-align: center; color: #8a8a99; font-size: 26rpx; line-height: 1.8; }
