<view class="page">
  <view class="quota-tip">{{memberLevel === 'member' ? '会员' : '免费版'}}收藏 {{outfitCount}}/{{outfitLimit}} 套</view>

  <view class="grid">
    <view class="card" wx:for="{{items}}" wx:key="id">
      <view class="card-name" data-item="{{item}}" bindtap="rename">
        <text class="name-text {{item.name ? '' : 'name-empty'}}">{{item.name || '未命名套装'}}</text>
        <text class="name-edit">✎</text>
      </view>
      <image class="card-img" src="{{baseUrl}}{{item.imageUrl}}" mode="aspectFill" data-id="{{item.id}}" bindtap="toggleItems" />
      <view class="card-parts" wx:if="{{openId === item.id}}">
        <text class="parts-tip" wx:if="{{item.items.length}}">生成时的单品配件（点击预选，可多选）</text>
        <text class="parts-tip" wx:else>（无配件记录）</text>
        <scroll-view scroll-x class="parts-row" wx:if="{{item.items.length}}">
          <view class="part {{selected[part.category] === part.imageUrl ? 'sel' : ''}}" wx:for="{{item.items}}" wx:for-item="part" wx:key="imageUrl"
                data-cat="{{part.category}}" data-url="{{part.imageUrl}}" catchtap="togglePart">
            <image class="part-img" src="{{baseUrl}}{{part.imageUrl}}" mode="aspectFill" />
            <text class="part-cat">{{labels[part.category]}}</text>
            <text class="part-check" wx:if="{{selected[part.category] === part.imageUrl}}">✓</text>
          </view>
        </scroll-view>
        <button class="use-parts" wx:if="{{item.items.length}}" disabled="{{selectedCount === 0}}" size="mini" catchtap="useParts">
          把选中配件填入首页生成{{selectedCount ? '（' + selectedCount + ' 件）' : ''}}
        </button>
      </view>
      <view class="card-bar">
        <text class="card-date">{{item.createdAt}}</text>
        <view class="card-actions">
          <text class="action" data-url="{{item.imageUrl}}" bindtap="preview">🔍</text>
          <text class="action" data-url="{{item.imageUrl}}" bindtap="save">⬇</text>
          <text class="action danger" data-id="{{item.id}}" bindtap="remove">🗑</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && items.length === 0}}">
    <text>还没有收藏的套装\n在生成结果页点「收藏套装」即可保存到这里</text>
  </view>
</view>
