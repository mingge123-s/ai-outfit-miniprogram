<view class="page">
  <view class="profile card">
    <view class="avatar">👤</view>
    <view class="info">
      <text class="name">账号 #{{me.userId}}</text>
      <text class="sub">{{me.devMode ? '开发模式登录' : '微信登录'}} · {{me.createdAt}}</text>
    </view>
    <view class="level">{{me.memberLevel === 'free' ? '免费版' : me.memberLevel}}</view>
  </view>

  <view class="stats card">
    <view class="stat" bindtap="goWardrobe">
      <text class="num">{{me.wardrobeCount}}</text>
      <text class="label">衣柜单品</text>
    </view>
    <view class="divider" />
    <view class="stat" bindtap="goCollection">
      <text class="num">{{me.outfitCount}}</text>
      <text class="label">收藏套装</text>
    </view>
    <view class="divider" />
    <view class="stat">
      <text class="num">{{me.remainingToday}}</text>
      <text class="label">今日剩余次数</text>
    </view>
  </view>

  <view class="photos card">
    <text class="photos-title">我的模特照（全身照，可多张，点击直接用于生成）</text>
    <view class="photos-grid">
      <view class="photo" wx:for="{{photos}}" wx:key="id" data-photo="{{item}}" bindtap="usePhoto">
        <image class="photo-img" src="{{baseUrl}}{{item.imageUrl}}" mode="aspectFill" />
        <view class="photo-del" catchtap="removePhoto" data-id="{{item.id}}">×</view>
      </view>
      <view class="photo photo-add" bindtap="addPhoto">
        <text class="photo-plus">＋</text>
      </view>
    </view>
  </view>

  <view class="vip card" bindtap="openVip">
    <view class="vip-left">
      <text class="vip-title">👑 开通会员</text>
      <text class="vip-sub">解锁高清生成、更多次数与专属背景</text>
    </view>
    <text class="vip-btn">充值</text>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="contact">
      <text>💬 联系客服</text><text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text>ℹ️ 关于小程序</text><text class="arrow">›</text>
    </view>
  </view>
</view>
