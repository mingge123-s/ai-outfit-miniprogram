<view class="page">
  <view class="profile card">
    <view class="avatar">👤</view>
    <view class="info">
      <text class="name">账号 #{{me.userId}}</text>
      <text class="sub">{{me.devMode ? '开发模式登录' : '微信登录'}} · {{me.createdAt}}</text>
    </view>
    <view class="level">{{me.memberLevel === 'free' ? '免费版' : me.memberLevel}}</view>
  </view>

  <view class="stats card">
    <view class="stat" bindtap="goWardrobe">
      <text class="num">{{me.wardrobeCount}}</text>
      <text class="label">衣柜单品</text>
    </view>
    <view class="divider" />
    <view class="stat" bindtap="goCollection">
      <text class="num">{{me.outfitCount}}</text>
      <text class="label">收藏套装</text>
    </view>
    <view class="divider" />
    <view class="stat">
      <text class="num">{{me.remainingToday}}</text>
      <text class="label">今日剩余次数</text>
    </view>
    <view class="divider" />
    <view class="stat">
      <text class="num">{{me.credits}}</text>
      <text class="label">剩余积分</text>
    </view>
  </view>

  <view class="photos card">
    <text class="photos-title">我的模特照（全身照，可多张，点击直接用于生成）</text>
    <view class="photos-grid">
      <view class="photo" wx:for="{{photos}}" wx:key="id" data-photo="{{item}}" bindtap="usePhoto">
        <image class="photo-img" src="{{baseUrl}}{{item.imageUrl}}" mode="aspectFill" />
        <view class="photo-del" catchtap="removePhoto" data-id="{{item.id}}">×</view>
      </view>
      <view class="photo photo-add" bindtap="addPhoto">
        <text class="photo-plus">＋</text>
      </view>
    </view>
  </view>

  <view class="history card">
    <view class="history-head">
      <text class="photos-title">生成历史（未收藏也会保留）</text>
      <text class="history-count">{{history.length}} 条</text>
    </view>
    <scroll-view class="history-row" scroll-x enable-flex wx:if="{{history.length}}">
      <view class="history-item" wx:for="{{history}}" wx:key="id">
        <image
          class="history-img"
          wx:if="{{item.imageUrl}}"
          src="{{baseUrl}}{{item.imageUrl}}"
          mode="aspectFill"
          data-url="{{item.imageUrl}}"
          bindtap="previewHistory"
        />
        <view class="history-placeholder" wx:else>
          <text>{{item.status === 'failed' ? '生成失败' : item.status === 'processing' ? '生成中…' : '排队中…'}}</text>
        </view>
        <text class="history-status {{item.status}}">{{item.status === 'done' ? '已完成' : item.status === 'failed' ? '失败' : item.status === 'processing' ? '生成中' : '排队中'}}</text>
        <view
          class="history-del"
          wx:if="{{item.status === 'done' || item.status === 'failed'}}"
          data-id="{{item.id}}"
          catchtap="removeHistory"
        >×</view>
      </view>
    </scroll-view>
    <text class="history-empty" wx:else>还没有生成记录</text>
  </view>

  <view class="vip card" bindtap="redeem">
    <view class="vip-left">
      <text class="vip-title">🎁 兑换码充值</text>
      <text class="vip-sub">今日免费 {{me.remainingFreeToday}}/{{me.dailyLimit}} 次，用尽后消耗积分</text>
    </view>
    <text class="vip-btn">兑换</text>
  </view>

  <view class="vip card" bindtap="openVip">
    <view class="vip-left">
      <text class="vip-title">👑 开通会员</text>
      <text class="vip-sub">解锁高清生成、更多次数与专属背景（即将开放）</text>
    </view>
    <text class="vip-btn">敬请期待</text>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="contact">
      <text>💬 联系客服</text><text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text>ℹ️ 关于小程序</text><text class="arrow">›</text>
    </view>
  </view>
</view>
