.page { padding: 24rpx 32rpx 60rpx; }
.card { background: #fff; border-radius: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); margin-bottom: 24rpx; }

.profile { display: flex; align-items: center; padding: 32rpx; }
.photos { padding: 24rpx; }
.photos-title { font-size: 24rpx; color: #55556b; display: block; margin-bottom: 16rpx; }
.photos-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo { position: relative; width: 150rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; background: #f6f6f8; }
.photo-img { width: 100%; height: 100%; }
.photo-del { position: absolute; top: 6rpx; right: 6rpx; width: 36rpx; height: 36rpx; line-height: 32rpx; text-align: center; background: rgba(0,0,0,0.55); color: #fff; border-radius: 50%; font-size: 24rpx; }
.photo-add { display: flex; align-items: center; justify-content: center; border: 2rpx dashed #d5d5e0; }
.photo-plus { font-size: 48rpx; color: #8a8a99; }
.history { padding: 24rpx; }
.history-head { display: flex; justify-content: space-between; align-items: center; }
.history-count { color: #8a8a99; font-size: 22rpx; margin-bottom: 16rpx; }
.history-row { white-space: nowrap; display: flex; }
.history-item {
  position: relative; display: inline-block; width: 180rpx; height: 240rpx; margin-right: 16rpx;
  border-radius: 14rpx; overflow: hidden; background: #eef3f5;
}
.history-img { width: 100%; height: 100%; }
.history-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #777587; font-size: 24rpx; }
.history-status {
  position: absolute; left: 8rpx; bottom: 8rpx; padding: 4rpx 12rpx; border-radius: 999rpx;
  background: rgba(71,97,111,.88); color: #fff; font-size: 20rpx;
}
.history-status.failed { background: rgba(110,85,85,.88); }
.history-del {
  position: absolute; right: 8rpx; top: 8rpx; width: 36rpx; height: 36rpx; line-height: 32rpx;
  text-align: center; border-radius: 50%; background: rgba(0,0,0,.55); color: #fff; font-size: 24rpx;
}
.history-empty { display: block; color: #8a8a99; font-size: 24rpx; padding: 10rpx 0; }
.avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: #eef3f5; display: flex; align-items: center; justify-content: center; font-size: 48rpx; margin-right: 24rpx; }
.info { flex: 1; display: flex; flex-direction: column; }
.name { font-size: 32rpx; font-weight: 600; }
.sub { font-size: 22rpx; color: #8a8a99; margin-top: 6rpx; }
.level { background: #eef3f5; color: #5c7c8d; font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 20rpx; }
.level-member { background: #fff1d6; color: #a76612; }

.stats { display: flex; padding: 28rpx 0; }
.stat { flex: 1; display: flex; flex-direction: column; align-items: center; }
.num { font-size: 40rpx; font-weight: 700; color: #5c7c8d; }
.label { font-size: 22rpx; color: #8a8a99; margin-top: 6rpx; }
.divider { width: 1rpx; background: #f2f2f6; }

.vip { display: flex; align-items: center; padding: 28rpx 32rpx; background: linear-gradient(90deg, #fff7e6, #ffefe0); }
.vip-left { flex: 1; display: flex; flex-direction: column; }
.vip-title { font-size: 30rpx; font-weight: 600; color: #b45309; }
.vip-sub { font-size: 22rpx; color: #b45309; opacity: 0.8; margin-top: 6rpx; }
.vip-btn { background: #b99a5f; color: #fff; font-size: 24rpx; padding: 12rpx 32rpx; border-radius: 30rpx; }
.ad-reward { display: flex; align-items: center; padding: 28rpx 32rpx; background: linear-gradient(90deg, #eef8f4, #e8f2f8); }
.ad-title, .ad-sub { color: #397064; }
.ad-btn { background: #4f8075; }

.menu { padding: 0 32rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #f2f2f6; font-size: 28rpx; }
.menu-item:last-child { border-bottom: 0; }
.arrow { color: #c0c0cc; font-size: 32rpx; }
